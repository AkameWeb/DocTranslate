# Включить сжатие
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json text/xml application/xml
    # Дополнительное сжатие для шрифтов
    AddOutputFilterByType DEFLATE font/ttf font/otf image/svg+xml
</IfModule>

# Кэширование статики (улучшенная версия)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    # Изображения - 1 год
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
    
    # CSS и JS - 1 месяц
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # Шрифты - 1 год
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # PDF и документы - 1 месяц
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType application/msword "access plus 1 month"
    ExpiresByType application/vnd.openxmlformats-officedocument.wordprocessingml.document "access plus 1 month"
</IfModule>

# Дополнительные заголовки для кэширования
<IfModule mod_headers.c>
    # Для статических файлов
    <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|svg|js|css|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    
    # Отключаем кэширование для HTML/PHP
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Безопасность
<FilesMatch "\.(env|log|sql|ini|lock|json|yml|yaml|md|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Дополнительная защита
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# Защита от доступа к папкам
Options -Indexes

# Запрет прямого доступа к папке uploads и её содержимому (файлы должны отдаваться только через скрипты)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^uploads/.*$ - [F,L]
</IfModule>

# Перенаправление с HTTP на HTTPS (для продакшена)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]